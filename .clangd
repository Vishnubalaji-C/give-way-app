# 🛡️ MakeWay IDE Stability Patch
# Silences background clangd noise for Arduino files which don't have a full toolchain present.
If:
  PathMatch: ".*\\.ino"
CompileFlags:
  Add: 
    - "-xc++"
    - "-w"
Diagnostics:
  Suppress: ["*"]
---
# Global Diagnostics Suppression
Diagnostics:
  Suppress: 
    - "compilation_database_not_found"
    - "drv_unknown_argument"
